# Production domain (without protocol) e.g. dropdeploy.co
ROOT_DOMAIN=yourdomain.com

# Full URL for SEO metadata
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# SQLite database path (default: data/drop-deploy.db)
# DATABASE_URL=data/drop-deploy.db

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...   # $7/month
STRIPE_PRICE_PRO=price_...       # $19/month
STRIPE_PRICE_SINGLE=price_...    # $3 one-time

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Drop Deploy <hello@dropdeploy.co>

# ── Cron protection ──────────────────────────────────────────────────────────
# Add ?secret=YOUR_SECRET or Authorization: Bearer YOUR_SECRET to cron calls
CRON_SECRET=your-random-secret
